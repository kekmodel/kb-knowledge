# Optional API key for OpenAI or authenticated OpenAI-compatible endpoints.
OPENAI_API_KEY=

# Optional endpoint default used by `kb-knowledge run-kakaobank-task(s)`.
# Accepts either a /v1 base URL or a full /chat/completions URL.
# OPENAI_COMPATIBLE_ENDPOINT=http://localhost:8000/v1

# OPENAI_BASE_URL is also supported as a fallback when
# OPENAI_COMPATIBLE_ENDPOINT is not set.
# OPENAI_BASE_URL=http://localhost:8000/v1
